    "test:quick": "vitest --run --reporter=dot",
    "test:integration": "vitest run --config vitest.workspace.ts --project integration",
    "test:integration:watch": "vitest --config vitest.workspace.ts --project integration",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "docs:generate": "next-openapi-gen generate",
    "typecheck": "tsc --noEmit"
  },
