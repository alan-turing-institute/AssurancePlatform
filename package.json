    "build": "next build",
    "start": "node server.js",
    "lint": "ultracite lint",
    "format": "ultracite format",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:unit": "vitest run --config vitest.workspace.ts --project unit",
    "test:fast": "vitest run --config vitest.workspace.ts --project unit --reporter=dot",
    "test:coverage": "COVERAGE=true vitest --coverage",
